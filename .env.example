# Mantle — optional environment variables and MCP snippets.
# Nothing here is required. Copy to .env and fill in only what you need.

# ──────────────────────────────────────────────────────────────────────────
# Optional MCP servers (paste into .mcp.json under "mcpServers" to enable)
# ──────────────────────────────────────────────────────────────────────────
#
# Supabase MCP:
#   "supabase": {
#     "type": "http",
#     "url": "https://mcp.supabase.com/mcp",
#     "env": { "SUPABASE_ACCESS_TOKEN": "..." }
#   }
#
# Apify MCP:
#   "apify": {
#     "type": "sse",
#     "url": "https://mcp.apify.com/sse",
#     "env": { "APIFY_TOKEN": "..." }
#   }
#
# Linear MCP, GitHub MCP, etc. — see https://github.com/modelcontextprotocol/servers

# ──────────────────────────────────────────────────────────────────────────
# Project secrets (uncomment + fill as needed)
# ──────────────────────────────────────────────────────────────────────────

# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# APIFY_TOKEN=
# EXA_API_KEY=
